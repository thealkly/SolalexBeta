# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.venv/
venv/
.env
.env.*
!.env.example

# uv
# NOTE: uv.lock IS committed — single source of truth with pyproject.toml

# Node / Frontend
node_modules/
dist/
.svelte-kit/
*.log
.eslintcache

# Frontend build output (Svelte/Vite)
frontend/dist/
frontend/.vite/

# Build artifacts
build/
out/

# Home Assistant runtime data (local dev only — never committed)
# `data/` (no leading slash) matches at any depth, so this one entry covers
# both `/data/` at repo root and any nested `data/` a test fixture creates.
data/

# Secrets.
# Gitignore negation (`!foo`) only re-includes a path if NONE of its
# parent directories are excluded. Our `*.key` pattern matches files,
# not directories, so `addon/example-certs/` stays visible and the
# negation below does take effect for `*.key.example` files.
*.pem
*.key
*.crt
!*.key.example

# Logs
logs/
*.log
